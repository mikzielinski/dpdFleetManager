# UiPath Coded Web App — skopiuj jako .env przed `npm run build`.
# Vite osadza VITE_* w bundle; bez poprawnego builda Studio Web nie zaloguje użytkownika.

# --- Auth mode ---
# false (produkcja / staging cloud) = OAuth PKCE + prawdziwe Data Fabric / Maestro
# true = UI bez logowania + mock DPD_POC (tylko lokalny dev)
VITE_BYPASS_AUTH=false

UIPATH_PROJECT_ID=28ac09c2-3a5c-4ba8-a78c-80883f38e6b5

# --- UiPath staging (Automation Cloud) ---
VITE_UIPATH_CLIENT_ID=98aa3ef7-06e0-431b-9997-1963d708bd45
VITE_UIPATH_ORG_NAME=mzpocevylrxu
VITE_UIPATH_TENANT_NAME=DefaultTenant
VITE_UIPATH_BASE_URL=https://staging.api.uipath.com
VITE_UIPATH_SCOPE=DataFabric.Schema.Read DataFabric.Data.Read PIMS OR.Execution OR.Jobs OR.Folders.Read

# Redirect URI (jak w sample process-app-v1: VITE_UIPATH_REDIRECT_URI || location).
# Hosted: zostaw puste — użyje meta uipath:redirect-uri lub URL z paska (…/dpdmonitoring).
# Lokalnie: http://localhost:5173
# VITE_UIPATH_REDIRECT_URI=http://localhost:5173

# =============================================================================
# Staging cloud — hosted Coded Web App (*.staging.uipath.host)
# =============================================================================
#
# Aplikacja (Orchestrator): https://c9ffe0f3-25c8-4539-a40f-1cb8e9248fd2.staging.uipath.host/dpdmonitoring
# Redirect URI w kodzie: origin + pathname, BEZ query (?origin=orchestratorFolder itd.)
#
# Admin → External Applications (staging):
#   https://staging.uipath.com/mzpocevylrxu/portal_/admin/external-apps/oauth
#
# Kroki:
#   1. Add Application → Non-Confidential (Authorization Code + PKCE, bez client secret)
#   2. Application ID = VITE_UIPATH_CLIENT_ID powyżej
#   3. User scopes (Add Scopes) — minimum:
#        Data Fabric: DataFabric.Schema.Read, DataFabric.Data.Read
#        Processes:   PIMS, OR.Execution, OR.Jobs, OR.Folders.Read
#   4. Redirect URL — zarejestruj DOKŁADNIE (oba warianty slasha zalecane):
#
# Hosted — zarejestruj OBA hosty (org name + org id), z i bez slasha:
#   https://mzpocevylrxu.staging.uipath.host/dpdmonitoring
#   https://mzpocevylrxu.staging.uipath.host/dpdmonitoring/
#   https://c9ffe0f3-25c8-4539-a40f-1cb8e9248fd2.staging.uipath.host/dpdmonitoring
#   https://c9ffe0f3-25c8-4539-a40f-1cb8e9248fd2.staging.uipath.host/dpdmonitoring/
#
# Studio Web designer (jeśli testujesz podgląd w designerze — skopiuj z paska adresu):
#   https://staging.uipath.com/mzpocevylrxu/studio_/designer/<project-guid>
#   (+ wariant z końcowym /)
#
# Lokalny dev (npm run dev):
#   http://localhost:5173
#   http://localhost:5173/
#
# OAuth flow (UiPath API guide): non-confidential + user scopes → Authorization Code + PKCE.
# Authorize: {VITE_UIPATH_BASE_URL}/{org}/identity_/connect/authorize
# Token:     {VITE_UIPATH_BASE_URL}/{org}/identity_/connect/token
# redirect_uri w authorize i token MUSI być identyczny z zarejestrowanym URL.
#
# Deploy:
#   npm run build
#   uip login --organization mzpocevylrxu --tenant DefaultTenant
#   uip codedapp push 28ac09c2-3a5c-4ba8-a78c-80883f38e6b5
