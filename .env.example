# UiPath Coded Web App — skopiuj jako .env przed `npm run build`.
# Vite osadza VITE_* w bundle; bez poprawnego builda Studio Web nie zaloguje użytkownika.

# --- Auth mode ---
# false (produkcja / staging cloud) = OAuth PKCE + prawdziwe Data Fabric / Maestro
# true = UI bez logowania + mock DPD_POC (tylko lokalny dev)
VITE_BYPASS_AUTH=false

UIPATH_PROJECT_ID=28ac09c2-3a5c-4ba8-a78c-80883f38e6b5

# --- UiPath staging (Automation Cloud) ---
VITE_UIPATH_CLIENT_ID=98aa3ef7-06e0-431b-9997-1963d708bd45
VITE_UIPATH_ORG_NAME=mzpocevylrxu
VITE_UIPATH_TENANT_NAME=DefaultTenant
VITE_UIPATH_BASE_URL=https://staging.api.uipath.com
VITE_UIPATH_SCOPE=DataFabric.Schema.Read DataFabric.Data.Read PIMS OR.Execution OR.Jobs OR.Folders.Read

# Redirect URI — pełna dokumentacja: docs/OAUTH-AND-REDIRECT.md
# Hosted: zostaw puste (meta uipath:redirect-uri lub URL z paska).
# Lokalnie: http://localhost:5173
# VITE_UIPATH_REDIRECT_URI=http://localhost:5173
#
# Deploy:
#   npm run build
#   uip login --organization mzpocevylrxu --tenant DefaultTenant
#   uip codedapp push 28ac09c2-3a5c-4ba8-a78c-80883f38e6b5
