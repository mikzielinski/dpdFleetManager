# Production Automation Cloud — skopiuj jako .env przed `npm run build`
# Szczegóły migracji: docs/MIGRATION-STAGING-TO-PRODUCTION.md

VITE_BYPASS_AUTH=false

UIPATH_PROJECT_ID=<PRODUCTION_STUDIO_PROJECT_GUID>

VITE_UIPATH_CLIENT_ID=<PRODUCTION_EXTERNAL_APP_CLIENT_ID>
VITE_UIPATH_ORG_NAME=<production-org-name>
VITE_UIPATH_TENANT_NAME=<ProductionTenantName>
VITE_UIPATH_BASE_URL=https://cloud.uipath.com
VITE_UIPATH_SCOPE=DataFabric.Schema.Read DataFabric.Data.Read PIMS OR.Execution OR.Jobs OR.Folders.Read

# Hosted redirect (musi być zarejestrowany w External Application):
# VITE_UIPATH_REDIRECT_URI=https://<production-org-name>.uipath.host/dpdmonitoring
